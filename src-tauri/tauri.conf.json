{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sneaker",
  "version": "0.1.0",
  "identifier": "com.sneaker.notes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Sneaker",
        "width": 420,
        "height": 560,
        "minWidth": 300,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
